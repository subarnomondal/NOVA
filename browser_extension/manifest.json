{
    "manifest_version": 3,
    "name": "Nova AI Assistant",
    "version": "1.1.0",
    "description": "Your personal AI assistant — chat with Nova from any browser tab.",
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:5000/*",
        "<all_urls>"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "nova-ai-assistant@nova-ai.com",
            "strict_min_version": "109.0"
        }
    }
}